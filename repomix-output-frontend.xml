                            <Col md={6}>
                                <Form.Group>
                                    <Form.Label className="fw-semibold small text-muted text-uppercase mb-1">Nhà phân phối</Form.Label>
                                    <Form.Select name="distributor_id" value={formData.distributor_id} onChange={handleChange}>
