            <Table responsive hover className="custom-table border-0 shadow-sm">
                <thead>
                    <tr>
                        <th style={{ width: '80px' }} className="ps-4">Ảnh</th>
                        <th>Thông tin sản phẩm</th>
                        <th>Danh mục</th>
